<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <LinearLayout
        android:id="@+id/launcher_landscape_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="@dimen/launcher_landscape_header_horizontal_padding"
        android:paddingTop="@dimen/launcher_landscape_header_vertical_padding"
        android:paddingEnd="@dimen/launcher_landscape_header_horizontal_padding"
        android:paddingBottom="@dimen/launcher_landscape_header_vertical_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/launcher_landscape_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:text="@string/landscape_launcher_title"
            android:textAllCaps="true"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/launcher_landscape_brand_text_size"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_heavy"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/play_nav_anchor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/landscape_nav_button_background_active"
                    android:minWidth="0dp"
                    android:paddingStart="@dimen/padding_tiny"
                    android:paddingEnd="@dimen/padding_extra_large"
                    android:text="@string/main_play"
                    android:textAllCaps="false"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/launcher_landscape_nav_text_size"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/manage_mods_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_large"
                    android:background="@drawable/landscape_nav_button_background"
                    android:minWidth="0dp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/main_manage_mods"
                    android:textAllCaps="false"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/launcher_landscape_nav_text_size" />

                <Button
                    android:id="@+id/launcher_more_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_large"
                    android:background="@drawable/landscape_nav_button_background"
                    android:minWidth="0dp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/landscape_launcher_more"
                    android:textAllCaps="false"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/launcher_landscape_nav_text_size" />

                <Button
                    android:id="@+id/launcher_settings_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_large"
                    android:background="@drawable/landscape_nav_button_background"
                    android:minWidth="0dp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/landscape_launcher_settings"
                    android:textAllCaps="false"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/launcher_landscape_nav_text_size" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/launcher_landscape_stage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background_app"
        android:paddingStart="@dimen/launcher_landscape_stage_padding"
        android:paddingTop="@dimen/launcher_landscape_stage_padding"
        android:paddingEnd="@dimen/launcher_landscape_stage_padding"
        android:paddingBottom="@dimen/launcher_landscape_stage_padding"
        app:layout_constraintBottom_toTopOf="@id/launcher_landscape_bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/launcher_landscape_header">

        <LinearLayout
            android:id="@+id/launcher_landscape_stage_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintWidth_max="@dimen/launcher_landscape_content_max_width"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/launcher_landscape_summary_card_height"
                android:layout_marginEnd="@dimen/launcher_landscape_summary_gap"
                android:layout_weight="1"
                android:background="@drawable/background_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/padding_large"
                android:paddingVertical="@dimen/padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:text="@string/landscape_summary_profile_label"
                    android:textAllCaps="true"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/launcher_landscape_summary_label_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/launcher_landscape_profile_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_medium"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textIsSelectable="true"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/launcher_landscape_summary_profile_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/launcher_landscape_summary_card_height"
                android:layout_marginHorizontal="@dimen/launcher_landscape_summary_gap"
                android:layout_weight="1"
                android:background="@drawable/background_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/padding_large"
                android:paddingVertical="@dimen/padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:text="@string/landscape_summary_version_label"
                    android:textAllCaps="true"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/launcher_landscape_summary_label_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/launcher_landscape_version_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_medium"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textIsSelectable="true"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/launcher_landscape_summary_version_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/launcher_landscape_summary_card_height"
                android:layout_marginStart="@dimen/launcher_landscape_summary_gap"
                android:layout_weight="1"
                android:background="@drawable/background_card"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/padding_large"
                android:paddingVertical="@dimen/padding_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:text="@string/landscape_summary_folder_label"
                    android:textAllCaps="true"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/launcher_landscape_summary_label_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/launcher_landscape_folder_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_medium"
                    android:ellipsize="middle"
                    android:maxLines="2"
                    android:textIsSelectable="true"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/launcher_landscape_summary_folder_text_size"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/launcher_landscape_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingStart="@dimen/launcher_landscape_bottom_bar_horizontal_padding"
        android:paddingTop="@dimen/launcher_landscape_bottom_bar_vertical_padding"
        android:paddingEnd="@dimen/launcher_landscape_bottom_bar_horizontal_padding"
        android:paddingBottom="@dimen/launcher_landscape_bottom_bar_vertical_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/launcher_landscape_bottom_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/launcher_landscape_content_max_width">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="@dimen/launcher_landscape_version_width"
                android:layout_height="@dimen/launcher_landscape_version_height"
                android:background="@android:color/transparent"
                android:drawableEnd="@drawable/spinner_arrow"
                app:drawableEndPadding="@dimen/_1sdp"
                app:drawableEndSize="@dimen/padding_heavy"
                app:drawableStartIntegerScaling="true"
                app:drawableStartSize="@dimen/_36sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/edit_profile_button"
                android:layout_width="@dimen/launcher_landscape_edit_button_size"
                android:layout_height="@dimen/launcher_landscape_edit_button_size"
                android:layout_marginStart="@dimen/padding_medium"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_edit_profile"
                app:layout_constraintBottom_toBottomOf="@id/mc_version_spinner"
                app:layout_constraintStart_toEndOf="@id/mc_version_spinner"
                app:layout_constraintTop_toTopOf="@id/mc_version_spinner" />

            <com.kdt.mcgui.LauncherPlayButton
                android:id="@+id/play_button"
                android:layout_width="@dimen/launcher_landscape_play_width"
                android:layout_height="@dimen/launcher_landscape_play_height"
                android:layout_marginStart="@dimen/padding_large"
                android:background="@drawable/play_button_background"
                android:text="@string/main_play"
                android:textAllCaps="true"
                android:textSize="@dimen/_26ssp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/edit_profile_button"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
